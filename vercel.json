{
  "version": 2,
  "name": "connectsphere-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/ConnectSphere/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "https://connectsphere-api.your-backend.com/auth/$1"
    },
    {
      "src": "/posts/(.*)",
      "dest": "https://connectsphere-api.your-backend.com/posts/$1"
    },
    {
      "src": "/(index\\.html|.*\\.(js|css|png|jpg|jpeg|svg|ico|json|woff|woff2|ttf))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
